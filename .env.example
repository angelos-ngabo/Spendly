# Firebase (Vite exposes only variables prefixed with VITE_)
# Create a Web app in the Firebase console and copy the config values.
#
# Troubleshooting:
# - File must be .env or .env.local in the SAME folder as package.json (not inside src/).
# - Every name must match exactly (e.g. VITE_FIREBASE_MESSAGING_SENDER_ID).
# - After editing, restart `npm run dev`. For production, set env vars before `npm run build`.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Canonical public URL of this app (used for Firebase email verification and password-reset continue URLs).
# Production (Vercel): set to your live origin, e.g. https://spendly-two-ochre.vercel.app (no trailing slash).
# Also add ONLY the hostname in Firebase → Authentication → Settings → Authorized domains:
#   spendly-two-ochre.vercel.app
# Leave unset in local dev to use http://localhost:<port> automatically.
# VITE_PUBLIC_APP_ORIGIN=
#
# Password reset emails (skip Firebase’s generic “Reset your password” web page):
# Firebase Console → Authentication → Templates → Password reset → pencil (edit).
# Set the action / handler URL to your Spendly reset route, same origin as above, e.g.:
#   https://spendly-two-ochre.vercel.app/reset-password
# (Local dev: http://localhost:5173/reset-password)
# Save the template. New emails should open Spendly directly with ?oobCode=…&mode=resetPassword in the URL.
#
# Email verification (skip Firebase’s hosted verify page; land on Spendly sign-in with success banner):
# Authentication → Templates → Email address verification → edit.
# Set action URL to your sign-in route, e.g. https://spendly-two-ochre.vercel.app/sign-in
# (Local: http://localhost:5173/sign-in). Legacy links may still use /verify-email.

# --- Branded auth emails (Resend + Vercel `/api/*` + Firebase Admin) ---
# Client: set to 1 to send reset/verify via your API instead of Firebase’s default templates.
# VITE_CUSTOM_AUTH_EMAILS=
# If the API is not same-origin (unusual), set the full origin of the API:
# VITE_EMAIL_API_BASE_URL=https://your-app.vercel.app
#
# Server-only (Vercel project / Environment Variables — never prefix with VITE_):
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=Spendly <onboarding@resend.dev>
# PUBLIC_APP_ORIGIN=https://your-app.vercel.app
# FIREBASE_ADMIN_PROJECT_ID=
# FIREBASE_ADMIN_CLIENT_EMAIL=
# FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
# Optional CORS (comma-separated origins); defaults to PUBLIC_APP_ORIGIN:
# CORS_ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:5173

# Optional (Google Analytics / Firebase Analytics in console)
# VITE_FIREBASE_MEASUREMENT_ID=

# --- Figma device exports (for landing page hero; not read by Vite) ---
# Create a personal access token in Figma → Settings → Security.
# Then run: npm run figma:devices
# (PowerShell) $env:FIGMA_ACCESS_TOKEN="..."; $env:FIGMA_LAPTOP_NODE_ID="3:87"; $env:FIGMA_PHONE_NODE_ID="3:88"; npm run figma:devices
# FIGMA_ACCESS_TOKEN=
# FIGMA_FILE_KEY=d5OZq7V9y5AjJ4AijwMtJ1
# FIGMA_LAPTOP_NODE_ID=
# FIGMA_PHONE_NODE_ID=

# Firebase (Vite exposes only variables prefixed with VITE_)
# Create a Web app in the Firebase console and copy the config values.
#
# Troubleshooting:
# - File must be .env or .env.local in the SAME folder as package.json (not inside src/).
# - Every name must match exactly (e.g. VITE_FIREBASE_MESSAGING_SENDER_ID).
# - After editing, restart `npm run dev`. For production, set env vars before `npm run build`.

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Optional (Google Analytics / Firebase Analytics in console)
# VITE_FIREBASE_MEASUREMENT_ID=

# --- Figma device exports (for landing page hero; not read by Vite) ---
# Create a personal access token in Figma → Settings → Security.
# Then run: npm run figma:devices
# (PowerShell) $env:FIGMA_ACCESS_TOKEN="..."; $env:FIGMA_LAPTOP_NODE_ID="3:87"; $env:FIGMA_PHONE_NODE_ID="3:88"; npm run figma:devices
# FIGMA_ACCESS_TOKEN=
# FIGMA_FILE_KEY=d5OZq7V9y5AjJ4AijwMtJ1
# FIGMA_LAPTOP_NODE_ID=
# FIGMA_PHONE_NODE_ID=
